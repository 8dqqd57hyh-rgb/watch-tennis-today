{
  "name": "watch-tennis-today",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:predeploy": "npm run lint && npm run typecheck && npm run build && playwright test",
    "test:predeploy:local": "npm run build && npm run start & wait-on http://localhost:3000 && playwright test",
    "cy:open": "cypress open",
    "cy:open:component": "cypress open --component",
    "cy:run": "node scripts/run-cypress.mjs",
    "cy:run:chrome": "node scripts/run-cypress.mjs --browser chrome",
    "cy:run:component": "cypress run --component",
    "cy:run:all": "npm run cy:run && npm run cy:run:component",
    "cy:run:smoke": "node scripts/run-cypress.mjs --expose grepTags=@smoke",
    "cy:run:seo": "node scripts/run-cypress.mjs --expose grepTags=@seo",
    "cy:run:critical": "node scripts/run-cypress.mjs --expose grepTags=@critical",
    "cy:run:api": "node scripts/run-cypress.mjs --expose grepTags=@api",
    "cy:run:journey": "node scripts/run-cypress.mjs --expose grepTags=@journey",
    "cy:run:accessibility": "node scripts/run-cypress.mjs --expose grepTags=@accessibility",
    "cy:report:merge": "mochawesome-merge \"cypress/reports/mochawesome/*.json\" > cypress/reports/mochawesome.json",
    "cy:report:html": "marge cypress/reports/mochawesome.json --reportDir cypress/reports/html --reportFilename index",
    "cy:report": "npm run cy:report:merge && npm run cy:report:html",
    "cy:predeploy": "start-server-and-test start http://localhost:3000 cy:run"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-cookie-consent": "^10.0.1",
    "react-dom": "19.2.4",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cypress/grep": "^6.0.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axe-core": "^4.12.1",
    "cypress": "^15.18.0",
    "cypress-axe": "^1.7.0",
    "cypress-multi-reporters": "^2.0.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
